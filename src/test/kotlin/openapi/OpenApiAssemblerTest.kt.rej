@@ -107,4 +107,24 @@
     assertEquals("1.0.0", assembled.info.version)
     assertEquals("API", assembled.info.title)
   }
+
+  @Test
+  fun `assemble paths without extensions merges cleanly`() {
+    val pathsWithNoExt = listOf(
+      EndpointDefinition(path = "/no-ext", method = HttpMethod.GET, operationId = "noExt1")
+    )
+    val basePathsWithNoExt = listOf(
+      EndpointDefinition(path = "/no-ext", method = HttpMethod.POST, operationId = "noExt2")
+    )
+    val baseApi = OpenApiDefinition(
+      openapi = "3.0.0",
+      info = Info(title = "Base", version = "1"),
+      endpoints = basePathsWithNoExt
+    )
+    val definitions = listOf(OpenApiDefinition(openapi = "3.0.0", info = Info(title = "Doc", version = "1"), endpoints = pathsWithNoExt))
+    
+    val assembled = OpenApiAssembler.assemble(baseApi, definitions)
+    val pathItem = assembled.paths["/no-ext"]
+    assertNotNull(pathItem)
+  }
 }
