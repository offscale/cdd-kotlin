# Auto-detect text files and ensure they have LF endings on checkout
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted to LF
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Declare files that must always have CRLF endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.wasm binary
